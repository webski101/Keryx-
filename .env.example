# DRY_RUN=1 simulates verify/settle without live network
DRY_RUN=1

# Port for the HTTP server (default 3000)
PORT=3000

# Seller wallet address (receives citation payments)
# Run: npm run generate-wallets
SELLER_ADDRESS=0x...
SELLER_PRIVATE_KEY=0x...

# Buyer agent wallet (pays citations)
BUYER_ADDRESS=0x...
BUYER_PRIVATE_KEY=0x...
